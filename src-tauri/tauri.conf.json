{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyNet",
  "version": "1.1.0",
  "identifier": "com.easynet.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EasyNet",
        "label": "main",
        "width": 610,
        "height": 640,
        "minWidth": 560,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "EasyNet - friendly GUI for ZeroTier",
    "longDescription": "A small, friendly GUI for ZeroTier, styled after Cloudflare WARP and as easy to use as Radmin VPN."
  }
}
